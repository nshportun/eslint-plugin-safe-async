{
  "name": "eslint-plugin-safe-async",
  "version": "0.0.1-development",
  "description": "ESLint rules for safer async/await code in JavaScript and TypeScript.",
  "license": "MIT",
  "author": "nshportun",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nshportun/eslint-plugin-safe-async.git"
  },
  "homepage": "https://www.npmjs.com/package/eslint-plugin-safe-async",
  "bugs": {
    "url": "https://github.com/nshportun/eslint-plugin-safe-async/issues"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "async",
    "await",
    "promises",
    "typescript",
    "javascript",
    "lint",
    "code-quality"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": "^20.0.0 || >=22.0.0"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "dev": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "npm run clean && npm run build",
    "pack:check": "npm pack --dry-run",
    "publint": "publint",
    "release:check": "npm run lint && npm run typecheck && npm run test && npm run build && npm run pack:check && npm run publint"
  },
  "devDependencies": {
    "@types/eslint": "^9.6.1",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@typescript-eslint/types": "^8.62.0",
    "@typescript-eslint/utils": "^8.62.0",
    "eslint": "^9.39.4",
    "publint": "^0.3.21",
    "rimraf": "^6.1.3",
    "tsconfig-paths": "^4.2.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
